APP_NAME=TaniTrade AI API
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=service-account.json
# Or set FIREBASE_SERVICE_ACCOUNT_JSON to the raw service account JSON string.
FIREBASE_SERVICE_ACCOUNT_JSON=
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_PRIMARY=gemini-3.1-flash-lite-preview
GEMINI_MODEL_LISTING=gemini-3.1-flash-lite-preview
GEMINI_TIMEOUT_SECONDS=20
GEMINI_MAX_RETRIES=2
AI_FALLBACK_ENABLED=true
AI_DEBUG_LOGGING=true
AI_LOG_FILE=logs/ai.log
DEMO_FARMER_PROFILE_ID=11111111-1111-1111-1111-111111111111
